generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model AccessRequest {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model Campaigns {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model Chat {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model Collection {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  created             DateTime @db.Date
  followersAre        String?
  isOpenCollaboration Boolean
  isPrivate           Boolean
  locationId          String?  @db.ObjectId
  priority            BigInt?
  profileId           String?  @db.ObjectId
  purpose             String
  title               String
  type                String?
  updated             DateTime @db.Date
}

model CollectionToCollection {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  childCollectionId  String   @db.ObjectId
  created            DateTime @db.Date
  index              BigInt?
  parentCollectionId String   @db.ObjectId
  profileId          String   @db.ObjectId
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  created   DateTime @db.Date
  parentId  String?  @db.ObjectId
  profileId String   @db.ObjectId
  storyId   String   @db.ObjectId
  updated   DateTime @db.Date
}

model Follow {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  approved    Boolean?
  created     DateTime @db.Date
  followerId  String   @db.ObjectId
  followingId String   @db.ObjectId
}

model Groups {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model Hashtag {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String @unique
}

model HashtagCollection {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  collectionId String   @db.ObjectId
  created      DateTime @db.Date
  hashtagId    String   @db.ObjectId
  profileId    String   @db.ObjectId
}

model HashtagComment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  commentId String   @db.ObjectId
  created   DateTime @db.Date
  hashtagId String   @db.ObjectId
  profileId String   @db.ObjectId
}

model HashtagFollower {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model HashtagStory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  created   DateTime @db.Date
  hashtagId String   @db.ObjectId
  profileId String   @db.ObjectId
  storyId   String   @db.ObjectId
}

model Location {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  created   DateTime? @db.Date
  latitude  Float
  longitude Float
}

model Message {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model Profile {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  created       DateTime  @db.Date
  isActive      Boolean
  isPrivate     Boolean
  lastActive    DateTime? @db.Date
  lastNotified  DateTime? @db.Date
  locationId    String?   @db.ObjectId
  profilePic    String
  selfStatement String
  userId        String?   @db.ObjectId
  username      String    @unique
  writerLevel   BigInt
}

model ProfileToCollection {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  collectionId String   @db.ObjectId
  created      DateTime @db.Date
  profileId    String   @db.ObjectId
  type         String
}

model Referral {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt   DateTime @db.Date
  createdById String   @db.ObjectId
  maxUses     BigInt
  updatedAt   DateTime @db.Date
  usageCount  BigInt
}

model RoleToCollection {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  approved     Boolean?
  collectionId String   @db.ObjectId
  created      DateTime @db.Date
  profileId    String   @db.ObjectId
  role         String
  updated      DateTime @db.Date
}

model RoleToStory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  approved  Boolean
  created   DateTime @db.Date
  profileId String   @db.ObjectId
  role      String
  storyId   String   @db.ObjectId
  updated   DateTime @db.Date
}

model Story {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  approvalScore BigInt
  authorId      String   @db.ObjectId
  commentable   Boolean
  created       DateTime @db.Date
  data          String
  description   String?
  isPrivate     Boolean
  needsFeedback Boolean?
  priority      BigInt?
  title         String
  type          String
  updated       DateTime @db.Date
}

model StoryToCollection {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  collectionId String   @db.ObjectId
  created      DateTime @db.Date
  index        BigInt?
  profileId    String?  @db.ObjectId
  storyId      String?  @db.ObjectId
}

model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  created        DateTime @db.Date
  email          String   @unique
  emailFrequency BigInt?
  firstLogin     Boolean?
  googleId       String?
  igHandle       String?
  lastEmailed    DateTime @db.Date
  password       String?
  preferredName  String
  referredById   String?  @db.ObjectId
  subscription   Stringx
  uId            Json?
  verified       Boolean
}

model UserCollectionHistory {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  collectionId String   @db.ObjectId
  created      DateTime @db.Date
  profileId    String   @db.ObjectId
}

model UserGroups {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model UserStoryHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  created   DateTime @db.Date
  profileId String   @db.ObjectId
  storyId   String   @db.ObjectId
}

model UserStoryLike {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  created   DateTime @db.Date
  profileId String   @db.ObjectId
  storyId   String   @db.ObjectId
}
